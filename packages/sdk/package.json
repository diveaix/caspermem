{
  "name": "@oxys/sdk",
  "version": "0.1.0",
  "description": "Memory, guardrail, and audit SDK for Casper AI agents.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./oxys-core": {
      "types": "./dist/oxys-core.d.ts",
      "import": "./dist/oxys-core.js"
    },
    "./aegis": {
      "types": "./dist/aegis.d.ts",
      "import": "./dist/aegis.js"
    },
    "./compute": {
      "types": "./dist/compute.d.ts",
      "import": "./dist/compute.js"
    },
    "./storage": {
      "types": "./dist/storage.d.ts",
      "import": "./dist/storage.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "casper",
    "cspr",
    "ai-agent",
    "mcp",
    "memory",
    "guardrails"
  ],
  "homepage": "https://oxys-liard.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/diveaix/caspermem.git",
    "directory": "packages/sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run clean && npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.25.76"
  }
}
