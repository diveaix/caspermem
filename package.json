{
  "name": "oxys",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @oxys/sdk && npm run build -w @oxys/api && npm run build -w @oxys/mcp && npm run build -w @oxys/backend && npm run build -w @oxys/web",
    "build:backend": "npm run build -w @oxys/sdk && npm run build -w @oxys/api && npm run build -w @oxys/mcp && npm run build -w @oxys/backend",
    "test": "npm run test -w @oxys/sdk && npm run test -w @oxys/api && npm run test -w @oxys/mcp",
    "backend:dev": "npm run dev -w @oxys/backend",
    "backend:start": "npm run start -w @oxys/backend",
    "api:dev": "tsx packages/api/src/server.ts",
    "api:smoke": "npm run build && tsx packages/api/examples/smoke.ts",
    "mcp:dev": "tsx packages/mcp/src/server.ts",
    "mcp:http:dev": "tsx packages/mcp/src/http.ts",
    "mcp:cspr:probe": "tsx packages/mcp/examples/cspr-trade-live.ts",
    "example:casper": "tsx packages/mcp/examples/cspr-trade-review-demo.ts",
    "web:dev": "npm run dev -w @oxys/web",
    "web:build": "npm run build -w @oxys/web",
    "web:preview": "npm run preview -w @oxys/web",
    "example:review": "tsx packages/sdk/examples/review-plan.ts",
    "example:seed": "tsx packages/sdk/examples/seed-memory.ts",
    "example:review-file": "tsx packages/sdk/examples/review-plan-file.ts packages/sdk/examples/fixtures/risky-plan.json",
    "example:outcome": "tsx packages/sdk/examples/record-outcome.ts",
    "example:flow": "tsx packages/sdk/examples/demo-flow.ts"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "playwright": "^1.61.0",
    "solc": "^0.8.28",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "dependencies": {
    "ethers": "^6.17.0"
  }
}
